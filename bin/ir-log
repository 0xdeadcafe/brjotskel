#!/usr/bin/env bash
# ir-log — Append an audit entry tagged with local execution context.
set -euo pipefail

log_dir="${BRJOTSKEL_LOG_DIR:-logs}"
mkdir -p "$log_dir"
log_file="$log_dir/audit-$(date -u +%Y%m%d).log"
host_name="$(hostname 2>/dev/null || uname -n 2>/dev/null || printf 'unknown-host')"
operator_name="${USER:-$(id -un 2>/dev/null || printf 'unknown-user')}"
ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

if [[ -n "${BRJOTSKEL_AUTH_CONTEXT:-}" ]]; then
  printf '%s auth=%q operator=%q host=%q event=%q\n' "$ts" "$BRJOTSKEL_AUTH_CONTEXT" "$operator_name" "$host_name" "$*" >> "$log_file"
else
  printf '%s operator=%q host=%q event=%q\n' "$ts" "$operator_name" "$host_name" "$*" >> "$log_file"
fi
