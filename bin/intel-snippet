#!/usr/bin/env python3
import argparse


def y(v, indent=0):
    sp = '  ' * indent
    if isinstance(v, dict):
        out = []
        for k, val in v.items():
            if isinstance(val, (dict, list)):
                out.append(f"{sp}{k}:")
                out.append(y(val, indent + 1))
            elif val is None:
                out.append(f"{sp}{k}: null")
            elif isinstance(val, bool):
                out.append(f"{sp}{k}: {'true' if val else 'false'}")
            elif isinstance(val, (int, float)):
                out.append(f"{sp}{k}: {val}")
            else:
                s = str(val)
                if any(c in s for c in [':', '#', '{', '}', '[', ']', ',', '&', '*']) or s.strip() != s or '\\' in s:
                    out.append(f'{sp}{k}: "{s.replace("\\", "\\\\").replace("\"", "\\\"")}"')
                else:
                    out.append(f"{sp}{k}: {s}")
        return '\n'.join(out)
    if isinstance(v, list):
        out = []
        for item in v:
            if isinstance(item, (dict, list)):
                out.append(f"{sp}-")
                out.append(y(item, indent + 1))
            elif item is None:
                out.append(f"{sp}- null")
            elif isinstance(item, bool):
                out.append(f"{sp}- {'true' if item else 'false'}")
            elif isinstance(item, (int, float)):
                out.append(f"{sp}- {item}")
            else:
                s = str(item)
                if any(c in s for c in [':', '#', '{', '}', '[', ']', ',', '&', '*']) or s.strip() != s or '\\' in s:
                    out.append(f'{sp}- "{s.replace("\\", "\\\\").replace("\"", "\\\"")}"')
                else:
                    out.append(f"{sp}- {s}")
        return '\n'.join(out)
    return f"{sp}{v}"


def compact(v):
    if isinstance(v, dict):
        out = {}
        for k, val in v.items():
            c = compact(val)
            if c in (None, [], {}):
                continue
            out[k] = c
        return out
    if isinstance(v, list):
        out = [compact(x) for x in v]
        return [x for x in out if x not in (None, [], {})]
    return v


def print_result(category, entry_id, data, summary):
    data = compact(data)
    yaml_text = y(data)
    print("=== YAML ===")
    print(yaml_text)
    print("\n=== intel_add ===")
    print(f'intel_add(category="{category}", id="{entry_id}", data="""{yaml_text}\n""", summary="{summary}")')


def add_common_source(obj, args):
    source = {}
    if getattr(args, 'source_host', None):
        source['host'] = args.source_host
    if getattr(args, 'source_method', None):
        source['method'] = args.source_method
    if getattr(args, 'source_path', None):
        source['path'] = args.source_path
    if getattr(args, 'source_tool', None):
        source['tool'] = args.source_tool
    if getattr(args, 'source_playbook', None):
        source['playbook'] = args.source_playbook
    if source:
        obj['source'] = source


def cmd_host(args):
    data = {
        'ip': args.ip,
        'hostname': args.hostname,
        'platform': args.platform,
        'role': args.role,
        'status': args.status,
        'attacker_role': args.attacker_role,
        'endpoints': args.endpoint or [],
        'profile_artifacts': args.profile_artifact or [],
    }
    if args.access_method:
        data['access'] = {
            'method': args.access_method,
            'credential': args.access_credential,
            'via': args.access_via,
            'port': args.access_port,
        }
    add_common_source(data, args)
    print_result('host', args.id, data, args.summary or f'Profile-derived host artifact recorded: {args.id}')


def cmd_credential(args):
    data = {
        'type': args.type,
        'username': args.username,
        'domain': args.domain,
        'status': args.status,
        'valid_on': args.valid_on or [],
        'related_hosts': args.related_host or [],
        'notes': args.notes,
    }
    if args.secret:
        data['secret'] = args.secret
    if args.key_file:
        data['key_file'] = args.key_file
    if args.ticket_file:
        data['ticket_file'] = args.ticket_file
    add_common_source(data, args)
    print_result('credential', args.id, data, args.summary or f'Credential artifact recorded: {args.id}')


def cmd_pivot(args):
    chain = [{
        'hop': args.hop,
        'method': args.method,
        'credential': args.credential,
        'command': args.command,
        'tunnel': args.tunnel,
    }]
    chain = [{k: v for k, v in x.items() if v is not None} for x in chain]
    data = {
        'target': args.target,
        'chain': chain,
        'status': args.status,
        'related_hosts': args.related_host or [],
        'notes': args.notes,
    }
    ev = {}
    if args.evidence_kind:
        ev['kind'] = args.evidence_kind
    if args.evidence_host:
        ev['host'] = args.evidence_host
    if args.evidence_path:
        ev['path'] = args.evidence_path
    if ev:
        data['evidence'] = [ev]
    add_common_source(data, args)
    print_result('pivot', args.id, data, args.summary or f'Profile-derived pivot recorded: {args.id}')


def cmd_putty_host(args):
    endpoint = f"ssh://{args.username}@{args.host}:{args.port}" if args.username else f"ssh://{args.host}:{args.port}"
    data = {
        'ip': args.ip,
        'hostname': args.hostname or args.host,
        'platform': args.platform,
        'role': args.role,
        'status': args.status,
        'attacker_role': args.attacker_role,
        'endpoints': [endpoint],
        'profile_artifacts': ['putty-session'],
    }
    if args.key_file or args.username:
        data['access'] = {
            'method': 'ssh',
            'credential': args.access_credential,
            'via': args.access_via,
            'port': args.port,
        }
    args.source_method = args.source_method or 'saved PuTTY session'
    args.source_path = args.source_path or f'HKCU\\Software\\SimonTatham\\PuTTY\\Sessions\\{args.session_name}'
    args.source_playbook = args.source_playbook or 'windows/putty-sessions.ps1'
    add_common_source(data, args)
    print_result('host', args.id, data, args.summary or f'PuTTY-derived endpoint recorded: {args.id}')


def cmd_ansible_host(args):
    endpoint = f"ssh://{args.username + '@' if args.username else ''}{args.host}:{args.port}"
    data = {
        'ip': args.ip,
        'hostname': args.hostname or args.inventory_name or args.host,
        'platform': args.platform,
        'role': args.role,
        'status': args.status,
        'attacker_role': args.attacker_role,
        'endpoints': [endpoint],
        'profile_artifacts': ['ansible-inventory'],
        'access': {
            'method': 'ssh',
            'credential': args.access_credential,
            'via': args.access_via,
            'port': args.port,
        }
    }
    args.source_method = args.source_method or 'ansible inventory'
    args.source_path = args.source_path or '/etc/ansible/hosts'
    args.source_tool = args.source_tool or 'ansible'
    args.source_playbook = args.source_playbook or 'linux/ansible-triage.sh'
    add_common_source(data, args)
    print_result('host', args.id, data, args.summary or f'Ansible-derived endpoint recorded: {args.id}')


def cmd_psreadline_credential(args):
    data = {
        'type': args.type,
        'username': args.username,
        'domain': args.domain,
        'status': args.status,
        'valid_on': args.valid_on or [],
        'related_hosts': args.related_host or [],
        'notes': args.notes or f'Observed in PSReadLine history line {args.line_number}' if args.line_number else args.notes,
    }
    if args.secret:
        data['secret'] = args.secret
    if args.key_file:
        data['key_file'] = args.key_file
    args.source_method = args.source_method or 'PSReadLine history'
    if not args.source_path and args.user_profile:
        args.source_path = rf'C:\Users\{args.user_profile}\AppData\Roaming\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt'
    args.source_playbook = args.source_playbook or 'windows/psreadline-history.ps1'
    add_common_source(data, args)
    if args.line_number:
        data['source'] = data.get('source', {})
        data['source']['line_number'] = args.line_number
    print_result('credential', args.id, data, args.summary or f'PSReadLine-derived credential artifact recorded: {args.id}')


def cmd_av_path_host(args):
    endpoint = args.endpoint or f"file://{args.exclusion_path}"
    data = {
        'hostname': args.hostname or args.id,
        'platform': args.platform,
        'role': args.role,
        'status': args.status,
        'attacker_role': args.attacker_role,
        'endpoints': [endpoint],
        'profile_artifacts': ['av-exclusion'],
        'notes': f"AV exclusion path observed: {args.exclusion_path}",
    }
    args.source_method = args.source_method or 'AV exclusion'
    args.source_path = args.source_path or args.registry_path or 'HKLM\\SOFTWARE\\Microsoft\\Windows Defender\\Exclusions\\Paths'
    args.source_playbook = args.source_playbook or 'windows/enum-av-exclusions.ps1'
    add_common_source(data, args)
    print_result('host', args.id, data, args.summary or f'AV exclusion artifact recorded: {args.id}')


def cmd_dnscache_host(args):
