    args.source_method = args.source_method or 'CIFS mount artifact'
    args.source_path = args.source_path or args.config_path
    args.source_playbook = args.source_playbook or 'linux/enum-cifs-creds.sh'
    add_common_source(data, args)
    print_result('pivot', args.id, data, args.summary or f'CIFS-derived pivot recorded: {args.id}')


def main():
