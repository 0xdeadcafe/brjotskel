    cifs.set_defaults(func=cmd_cifs_pivot)

    piv = sub.add_parser('pivot', parents=[common])
    piv.add_argument('--id', required=True)
    piv.add_argument('--target', required=True)
    piv.add_argument('--hop', required=True)
    piv.add_argument('--method', required=True)
    piv.add_argument('--credential')
    piv.add_argument('--command')
    piv.add_argument('--tunnel')
    piv.add_argument('--status', default='suspected')
    piv.add_argument('--related-host', action='append')
    piv.add_argument('--notes')
    piv.add_argument('--evidence-kind')
    piv.add_argument('--evidence-host')
    piv.add_argument('--evidence-path')
    piv.set_defaults(func=cmd_pivot)

    args = p.parse_args()
    args.func(args)


if __name__ == '__main__':
    main()
