    putty.add_argument('--platform', default='unknown')
    putty.add_argument('--role', default='unknown')
    putty.add_argument('--status', default='suspected')
    putty.add_argument('--attacker-role', default='unknown')
    putty.add_argument('--session-name', required=True)
    putty.add_argument('--key-file')
    putty.add_argument('--access-credential')
    putty.add_argument('--access-via')
