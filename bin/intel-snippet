    brw.add_argument('--browser')
    brw.add_argument('--platform', default='unknown')
    brw.add_argument('--role', default='unknown')
    brw.add_argument('--status', default='suspected')
    brw.add_argument('--attacker-role', default='unknown')
    brw.add_argument('--notes')
    brw.set_defaults(func=cmd_browser_host)

    cifs = sub.add_parser('cifs-pivot', parents=[common])
    cifs.add_argument('--id', required=True)
    cifs.add_argument('--target', required=True)
    cifs.add_argument('--hop', required=True)
    cifs.add_argument('--credential')
    cifs.add_argument('--command')
    cifs.add_argument('--status', default='suspected')
    cifs.add_argument('--related-host', action='append')
    cifs.add_argument('--notes')
    cifs.add_argument('--config-path')
