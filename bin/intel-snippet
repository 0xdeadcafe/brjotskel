def cmd_vpn_pivot(args):
    chain = [{
        'hop': args.hop,
        'method': args.method,
        'credential': args.credential,
        'command': args.command,
    }]
    data = {
        'target': args.target,
        'chain': chain,
        'status': args.status,
        'related_hosts': args.related_host or [],
        'notes': args.notes or f'VPN endpoint {args.remote_host}:{args.remote_port}' if args.remote_host else args.notes,
        'evidence': [{
            'kind': 'vpn-config',
            'host': args.source_host,
            'path': args.source_path or args.config_path,
        }]
    }
    args.source_method = args.source_method or 'VPN config'
    args.source_path = args.source_path or args.config_path
    args.source_playbook = args.source_playbook or 'linux/enum-vpn-creds.sh'
    add_common_source(data, args)
    print_result('pivot', args.id, data, args.summary or f'VPN-derived pivot recorded: {args.id}')


